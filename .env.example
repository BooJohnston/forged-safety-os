# ═══════════════════════════════════════════════════════════
# FORGED Safety Intelligence OS v4.0 — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Netlify: Set these in Site Settings → Environment Variables
# ═══════════════════════════════════════════════════════════

# ─── SUPABASE (Required) ───
# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── AI PROVIDERS (Required for AI features) ───
# These are SERVER-SIDE only — used by netlify/functions/ai-proxy.js
# Set in Netlify → Site Settings → Environment Variables (NOT prefixed with VITE_)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OPENAI_API_KEY=sk-your-openai-key-here
